// Problem: Daily Temperatures
// LeetCode 739
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(n²)
Space Complexity: O(1)
------------------------------------------------------------*/
vector<int> dailyTemperaturesBruteForce(vector<int> temperatures) {

    int n = temperatures.size();

    vector<int> ans(n, 0);

    for (int i = 0; i < n; i++) {

        for (int j = i + 1; j < n; j++) {

            if (temperatures[j] > temperatures[i]) {

                ans[i] = j - i;
                break;
            }
        }
    }

    return ans;
}

/*------------------------------------------------------------
Approach 2: Monotonic Stack (Optimal)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> dailyTemperaturesStack(vector<int> temperatures) {

    int n = temperatures.size();

    vector<int> ans(n, 0);

    stack<int> st;      // Stores indices

    for (int i = n - 1; i >= 0; i--) {

        while (!st.empty() &&
               temperatures[st.top()] <= temperatures[i]) {

            st.pop();
        }

        if (!st.empty()) {
            ans[i] = st.top() - i;
        }

        st.push(i);
    }

    return ans;
}

/*------------------------------------------------------------
Approach 3: Dynamic Programming (Jump Technique)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> dailyTemperaturesDP(vector<int> temperatures) {

    int n = temperatures.size();

    vector<int> ans(n, 0);

    for (int i = n - 2; i >= 0; i--) {

        int j = i + 1;

        while (j < n) {

            if (temperatures[j] > temperatures[i]) {

                ans[i] = j - i;
                break;
            }

            if (ans[j] == 0) {
                break;
            }

            j += ans[j];
        }
    }

    return ans;
}

// Function to print answer
void printAnswer(string approach, vector<int> ans) {

    cout << approach << endl;

    cout << "Output: ";

    for (int x : ans) {
        cout << x << " ";
    }

    cout << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<int> temperatures = {73,74,75,71,69,72,76,73};

    printAnswer("Approach 1: Brute Force",
                dailyTemperaturesBruteForce(temperatures));

    printAnswer("Approach 2: Monotonic Stack (Optimal)",
                dailyTemperaturesStack(temperatures));

    printAnswer("Approach 3: Dynamic Programming",
                dailyTemperaturesDP(temperatures));

    return 0;
}
