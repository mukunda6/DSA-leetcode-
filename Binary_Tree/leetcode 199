// Problem: Binary Tree Right Side View
// LeetCode 199
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Definition for a Binary Tree Node
------------------------------------------------------------*/

struct TreeNode {

    int val;
    TreeNode *left;
    TreeNode *right;

    TreeNode(int x) {

        val = x;
        left = NULL;
        right = NULL;
    }
};

/*------------------------------------------------------------
Approach 1: Level Order Traversal (BFS)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

vector<int> rightSideViewBFS(TreeNode* root) {

    vector<int> ans;

    // Empty tree.
    if (root == NULL) return ans;

    queue<TreeNode*> q;

    q.push(root);

    while (!q.empty()) {

        int size = q.size();

        for (int i = 0; i < size; i++) {

            TreeNode* node = q.front();
            q.pop();

            // Last node of the current level.
            if (i == size - 1) ans.push_back(node->val);

            // Push left child.
            if (node->left) q.push(node->left);

            // Push right child.
            if (node->right) q.push(node->right);
        }
    }

    return ans;
}

/*------------------------------------------------------------
Approach 2: DFS (Right First) - Optimal
Time Complexity: O(n)
Space Complexity: O(h)
------------------------------------------------------------*/

// Traverse the tree using DFS.
void rec(TreeNode* root, int level, vector<int>& ans) {

    // Empty tree.
    if (root == NULL) return;

    // First node visited at this level.
    if (level == ans.size()) ans.push_back(root->val);

    // Visit right subtree first.
    rec(root->right, level + 1, ans);

    // Visit left subtree.
    rec(root->left, level + 1, ans);
}

vector<int> rightSideViewDFS(TreeNode* root) {

    vector<int> ans;

    rec(root, 0, ans);

    return ans;
}

// Function to print answer.
void printAnswer(string approach, vector<int> ans) {

    cout << approach << endl;

    cout << "Right Side View: ";

    for (int x : ans)
        cout << x << " ";

    cout << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    /*
               1
              / \
             2   3
              \   \
               5   4
    */

    TreeNode* root = new TreeNode(1);

    root->left = new TreeNode(2);
    root->right = new TreeNode(3);

    root->left->right = new TreeNode(5);
    root->right->right = new TreeNode(4);

    printAnswer("Approach 1: Level Order Traversal (BFS)",
                rightSideViewBFS(root));

    printAnswer("Approach 2: DFS (Right First)",
                rightSideViewDFS(root));

    return 0;
}
