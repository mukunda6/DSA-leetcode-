// Problem: Same Tree
// LeetCode 100
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Definition for a Binary Tree Node
------------------------------------------------------------*/

struct TreeNode {

    int val;
    TreeNode *left;
    TreeNode *right;

    TreeNode(int x) {

        val = x;
        left = NULL;
        right = NULL;
    }
};

/*------------------------------------------------------------
Approach 1: Recursive DFS (Optimal)
Time Complexity: O(n)
Space Complexity: O(h)
------------------------------------------------------------*/

bool isSameTreeDFS(TreeNode* p, TreeNode* q) {

  // If either node is NULL,
    // return true only if both are NULL.
    if (p == NULL || q == NULL)
        return p == q;

    // Compare current node values
    // and recursively compare left and right subtrees.
    return p->val == q->val &&
           isSameTree(p->left, q->left) &&
           isSameTree(p->right, q->right);
}

/*------------------------------------------------------------
Approach 2: Iterative BFS (Queue)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

bool isSameTreeBFS(TreeNode* p, TreeNode* q) {

    queue<pair<TreeNode*, TreeNode*>> qu;

    qu.push({p, q});

    while (!qu.empty()) {

        auto current = qu.front();
        qu.pop();

        TreeNode* first = current.first;
        TreeNode* second = current.second;

        // Both are NULL
        if (first == NULL && second == NULL)
            continue;

        // One is NULL
        if (first == NULL || second == NULL)
            return false;

        // Values are different
        if (first->val != second->val)
            return false;

        qu.push({first->left, second->left});
        qu.push({first->right, second->right});
    }

    return true;
}

/*------------------------------------------------------------
Approach 3: Iterative DFS (Stack)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

bool isSameTreeStack(TreeNode* p, TreeNode* q) {

    stack<pair<TreeNode*, TreeNode*>> st;

    st.push({p, q});

    while (!st.empty()) {

        auto current = st.top();
        st.pop();

        TreeNode* first = current.first;
        TreeNode* second = current.second;

        // Both are NULL
        if (first == NULL && second == NULL)
            continue;

        // One is NULL
        if (first == NULL || second == NULL)
            return false;

        // Values are different
        if (first->val != second->val)
            return false;

        st.push({first->left, second->left});
        st.push({first->right, second->right});
    }

    return true;
}

// Function to print answer
void printAnswer(string approach, bool ans) {

    cout << approach << endl;

    cout << "Same Tree: "
         << (ans ? "True" : "False") << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    /*
          Tree 1        Tree 2

             1             1
            / \           / \
           2   3         2   3
    */

    TreeNode* p = new TreeNode(1);
    p->left = new TreeNode(2);
    p->right = new TreeNode(3);

    TreeNode* q = new TreeNode(1);
    q->left = new TreeNode(2);
    q->right = new TreeNode(3);

    printAnswer("Approach 1: Recursive DFS",
                isSameTreeDFS(p, q));

    printAnswer("Approach 2: Iterative BFS",
                isSameTreeBFS(p, q));

    printAnswer("Approach 3: Iterative DFS",
                isSameTreeStack(p, q));

    return 0;
}
