// Problem: Two Sum II - Input Array Is Sorted
// LeetCode 167
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(n²)
Space Complexity: O(1)
------------------------------------------------------------*/

vector<int> twoSumBruteForce(vector<int>& numbers, int target) {

    int n = numbers.size();

    // Check every pair.
    for (int i = 0; i < n; i++) {

        for (int j = i + 1; j < n; j++) {

            if (numbers[i] + numbers[j] == target)
                return {i + 1, j + 1};
        }
    }

    return {};
}

/*------------------------------------------------------------
Approach 2: Binary Search
Time Complexity: O(n log n)
Space Complexity: O(1)
------------------------------------------------------------*/

vector<int> twoSumBinarySearch(vector<int>& numbers, int target) {

    int n = numbers.size();

    // Fix one element and binary search the remaining value.
    for (int i = 0; i < n; i++) {

        int need = target - numbers[i];

        int left = i + 1;
        int right = n - 1;

        while (left <= right) {

            int mid = left + (right - left) / 2;

            if (numbers[mid] == need)
                return {i + 1, mid + 1};

            if (numbers[mid] < need)
                left = mid + 1;
            else
                right = mid - 1;
        }
    }

    return {};
}

/*------------------------------------------------------------
Approach 3: Hash Map
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

vector<int> twoSumHashMap(vector<int>& numbers, int target) {

    unordered_map<int, int> mp;

    // Store visited numbers.
    for (int i = 0; i < numbers.size(); i++) {

        int need = target - numbers[i];

        // Pair found.
        if (mp.count(need))
            return {mp[need] + 1, i + 1};

        // Store current number.
        mp[numbers[i]] = i;
    }

    return {};
}

/*------------------------------------------------------------
Approach 4: Two Pointers (Optimal)
Time Complexity: O(n)
Space Complexity: O(1)
------------------------------------------------------------*/

vector<int> twoSumTwoPointers(vector<int>& numbers, int target) {

    int i = 0;
    int j = numbers.size() - 1;

    while (i < j) {

        int sum = numbers[i] + numbers[j];

        // Pair found.
        if (sum == target) return {i + 1, j + 1};

        // Sum is too large.
        if (sum > target)
            j--;

        // Sum is too small.
        else
            i++;
    }

    return {};
}

// Function to print answer.
void printAnswer(string approach, vector<int> ans) {

    cout << approach << endl;

    cout << "Indices: ";

    for (int x : ans)
        cout << x << " ";

    cout << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<int> numbers = {2, 7, 11, 15};

    int target = 9;

    printAnswer("Approach 1: Brute Force",
                twoSumBruteForce(numbers, target));

    printAnswer("Approach 2: Binary Search",
                twoSumBinarySearch(numbers, target));

    printAnswer("Approach 3: Hash Map",
                twoSumHashMap(numbers, target));

    printAnswer("Approach 4: Two Pointers",
                twoSumTwoPointers(numbers, target));

    return 0;
}
