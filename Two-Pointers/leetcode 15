// Problem: 3Sum
// LeetCode 15
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(n³)
Space Complexity: O(k)
------------------------------------------------------------*/

vector<vector<int>> threeSumBruteForce(vector<int>& nums) {

    int n = nums.size();

    // Store unique triplets.
    set<vector<int>> st;

    // Check every possible triplet.
    for (int i = 0; i < n; i++) {

        for (int j = i + 1; j < n; j++) {

            for (int k = j + 1; k < n; k++) {

                if (nums[i] + nums[j] + nums[k] == 0) {

                    vector<int> temp = {nums[i], nums[j], nums[k]};

                    sort(temp.begin(), temp.end());

                    st.insert(temp);
                }
            }
        }
    }

    return vector<vector<int>>(st.begin(), st.end());
}

/*------------------------------------------------------------
Approach 2: Hash Set
Time Complexity: O(n²)
Space Complexity: O(n)
------------------------------------------------------------*/

vector<vector<int>> threeSumHashSet(vector<int>& nums) {

    int n = nums.size();

    // Store unique triplets.
    set<vector<int>> ans;

    for (int i = 0; i < n; i++) {

        unordered_set<int> seen;

        for (int j = i + 1; j < n; j++) {

            int need = -(nums[i] + nums[j]);

            // Triplet found.
            if (seen.count(need)) {

                vector<int> temp = {nums[i], nums[j], need};

                sort(temp.begin(), temp.end());

                ans.insert(temp);
            }

            seen.insert(nums[j]);
        }
    }

    return vector<vector<int>>(ans.begin(), ans.end());
}

/*------------------------------------------------------------
Approach 3: Sorting + Two Pointers (Optimal)
Time Complexity: O(n²)
Space Complexity: O(1) (Ignoring Output)
------------------------------------------------------------*/

vector<vector<int>> threeSumTwoPointers(vector<int>& nums) {

    sort(nums.begin(), nums.end());

    int n = nums.size();

    vector<vector<int>> ans;

    // Fix the first element.
    for (int i = 0; i < n; i++) {

        // Skip duplicate first elements.
        if (i > 0 && nums[i] == nums[i - 1]) continue;

        int j = i + 1;
        int k = n - 1;

        while (j < k) {

            int sum = nums[i] + nums[j] + nums[k];

            // Need a larger sum.
            if (sum < 0) {

                j++;
            }

            // Need a smaller sum.
            else if (sum > 0) {

                k--;
            }

            // Triplet found.
            else {

                ans.push_back({nums[i], nums[j], nums[k]});

                j++;
                k--;

                // Skip duplicate second elements.
                while (j < k && nums[j] == nums[j - 1])
                    j++;
            }
        }
    }

    return ans;
}

// Function to print answer.
void printAnswer(string approach, vector<vector<int>> ans) {

    cout << approach << endl;

    for (auto triplet : ans) {

        cout << "[ ";

        for (int x : triplet)
            cout << x << " ";

        cout << "]" << endl;
    }

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<int> nums = {-1, 0, 1, 2, -1, -4};

    printAnswer("Approach 1: Brute Force",
                threeSumBruteForce(nums));

    printAnswer("Approach 2: Hash Set",
                threeSumHashSet(nums));

    printAnswer("Approach 3: Two Pointers",
                threeSumTwoPointers(nums));

    return 0;
}
