// Problem: Two Sum
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(n²)
Space Complexity: O(1)
------------------------------------------------------------*/
vector<int> twoSumBruteForce(vector<int>& nums, int target) {

    for (int i = 0; i < nums.size(); i++) {

        for (int j = i + 1; j < nums.size(); j++) {

            if (nums[i] + nums[j] == target) {
                return {i, j};
            }
        }
    }

    return {};
}

/*------------------------------------------------------------
Approach 2: Hash Map
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> twoSumHashMap(vector<int>& nums, int target) {

    unordered_map<int, int> mp;

    for (int i = 0; i < nums.size(); i++) {

        int rem = target - nums[i];

        if (mp.find(rem) != mp.end()) {
            return {mp[rem], i};
        }

        mp[nums[i]] = i;
    }

    return {};
}

/*------------------------------------------------------------
Approach 3: Sorting + Two Pointers
Time Complexity: O(n log n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> twoSumTwoPointers(vector<int>& nums, int target) {

    vector<pair<int, int>> arr;

    // Store value and original index
    for (int i = 0; i < nums.size(); i++) {
        arr.push_back({nums[i], i});
    }

    sort(arr.begin(), arr.end());

    int left = 0;
    int right = arr.size() - 1;

    while (left < right) {

        int sum = arr[left].first + arr[right].first;

        if (sum == target) {
            return {arr[left].second, arr[right].second};
        }
        else if (sum < target) {
            left++;
        }
        else {
            right--;
        }
    }

    return {};
}

/*------------------------------------------------------------
Approach 4: Binary Search
Time Complexity: O(n log n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> twoSumBinarySearch(vector<int>& nums, int target) {

    vector<pair<int, int>> arr;

    // Store value and original index
    for (int i = 0; i < nums.size(); i++) {
        arr.push_back({nums[i], i});
    }

    sort(arr.begin(), arr.end());

    for (int i = 0; i < arr.size(); i++) {

        int rem = target - arr[i].first;

        int low = i + 1;
        int high = arr.size() - 1;

        while (low <= high) {

            int mid = low + (high - low) / 2;

            if (arr[mid].first == rem) {
                return {arr[i].second, arr[mid].second};
            }
            else if (arr[mid].first < rem) {
                low = mid + 1;
            }
            else {
                high = mid - 1;
            }
        }
    }

    return {};
}

// Function to print answer
void printAnswer(string approach, vector<int> ans) {

    cout << approach << endl;

    if (ans.empty()) {
        cout << "No Solution Found\n";
    }
    else {
        cout << "Indices: ";
        for (int x : ans)
            cout << x << " ";
        cout << endl;
    }

    cout << "----------------------------------------" << endl;
}

int main() {

    // Example Test Case
    vector<int> nums = {2, 7, 11, 15};
    int target = 9;

    printAnswer("Approach 1: Brute Force",
                twoSumBruteForce(nums, target));

    printAnswer("Approach 2: Hash Map",
                twoSumHashMap(nums, target));

    printAnswer("Approach 3: Sorting + Two Pointers",
                twoSumTwoPointers(nums, target));

    printAnswer("Approach 4: Binary Search",
                twoSumBinarySearch(nums, target));

    return 0;
}
