// Problem: Product of Array Except Self
// LeetCode 238
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(n²)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> productExceptSelfBruteForce(vector<int> nums) {

    int n = nums.size();

    vector<int> ans(n);

    for (int i = 0; i < n; i++) {

        int product = 1;

        for (int j = 0; j < n; j++) {

            if (i != j) {
                product *= nums[j];
            }
        }

        ans[i] = product;
    }

    return ans;
}

/*------------------------------------------------------------
Approach 2: Division Method (Not Allowed)
Time Complexity: O(n)
Space Complexity: O(1)
------------------------------------------------------------*/
vector<int> productExceptSelfDivision(vector<int> nums) {

    int product = 1;
    int zeroCount = 0;

    for (int num : nums) {

        if (num == 0) {
            zeroCount++;
        }
        else {
            product *= num;
        }
    }

    vector<int> ans(nums.size());

    for (int i = 0; i < nums.size(); i++) {

        if (zeroCount > 1) {
            ans[i] = 0;
        }
        else if (zeroCount == 1) {

            if (nums[i] == 0)
                ans[i] = product;
            else
                ans[i] = 0;
        }
        else {
            ans[i] = product / nums[i];
        }
    }

    return ans;
}

/*------------------------------------------------------------
Approach 3: Prefix & Suffix Arrays
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> productExceptSelfPrefixSuffix(vector<int> nums) {

    int n = nums.size();

    vector<int> prefix(n);
    vector<int> suffix(n);
    vector<int> ans(n);

    prefix[0] = 1;

    for (int i = 1; i < n; i++) {
        prefix[i] = prefix[i - 1] * nums[i - 1];
    }

    suffix[n - 1] = 1;

    for (int i = n - 2; i >= 0; i--) {
        suffix[i] = suffix[i + 1] * nums[i + 1];
    }

    for (int i = 0; i < n; i++) {
        ans[i] = prefix[i] * suffix[i];
    }

    return ans;
}

/*------------------------------------------------------------
Approach 4: Prefix + Running Suffix (Optimal)
Time Complexity: O(n)
Space Complexity: O(1)
------------------------------------------------------------*/
vector<int> productExceptSelfOptimal(vector<int> nums) {

    int n = nums.size();

    vector<int> ans(n);

    ans[0] = 1;

    // Prefix Product
    for (int i = 1; i < n; i++) {
        ans[i] = ans[i - 1] * nums[i - 1];
    }

    // Running Suffix Product
    int suffix = 1;

    for (int i = n - 1; i >= 0; i--) {

        ans[i] *= suffix;

        suffix *= nums[i];
    }

    return ans;
}

// Function to print answer
void printAnswer(string approach, vector<int> ans) {

    cout << approach << endl;

    cout << "Output: ";

    for (int x : ans) {
        cout << x << " ";
    }

    cout << endl;
    cout << "----------------------------------------" << endl;
}

int main() {

    vector<int> nums = {1, 2, 3, 4};

    printAnswer("Approach 1: Brute Force",
                productExceptSelfBruteForce(nums));

    printAnswer("Approach 2: Division Method",
                productExceptSelfDivision(nums));

    printAnswer("Approach 3: Prefix & Suffix Arrays",
                productExceptSelfPrefixSuffix(nums));

    printAnswer("Approach 4: Prefix + Running Suffix (Optimal)",
                productExceptSelfOptimal(nums));

    return 0;
}
