// Problem: Insert Interval
// LeetCode 57
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force (Insert + Merge)
Time Complexity: O(n log n)
Space Complexity: O(n)
------------------------------------------------------------*/

vector<vector<int>> insertBruteForce(vector<vector<int>>& intervals, vector<int>& newInterval) {

    // Insert the new interval.
    intervals.push_back(newInterval);

    // Sort all intervals.
    sort(intervals.begin(), intervals.end());

    vector<vector<int>> ans;

    for (auto interval : intervals) {

        // No overlap.
        if (ans.empty() || interval[0] > ans.back()[1]) {

            ans.push_back(interval);
        }

        // Merge intervals.
        else {

            ans.back()[1] = max(ans.back()[1], interval[1]);
        }
    }

    return ans;
}

/*------------------------------------------------------------
Approach 2: Optimal
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

vector<vector<int>> insertOptimal(vector<vector<int>>& intervals, vector<int>& newInterval) {

    vector<vector<int>> ans;

    int i = 0;
    int n = intervals.size();

    // Add all intervals before newInterval.
    while (i < n && intervals[i][1] < newInterval[0]) {

        ans.push_back(intervals[i]);

        i++;
    }

    // Merge all overlapping intervals.
    while (i < n && intervals[i][0] <= newInterval[1]) {

        newInterval[0] = min(newInterval[0], intervals[i][0]);

        newInterval[1] = max(newInterval[1], intervals[i][1]);

        i++;
    }

    ans.push_back(newInterval);

    // Add remaining intervals.
    while (i < n) {

        ans.push_back(intervals[i]);

        i++;
    }

    return ans;
}

// Function to print answer.
void printAnswer(string approach, vector<vector<int>> ans) {

    cout << approach << endl;

    for (auto interval : ans)
        cout << "[ " << interval[0] << ", " << interval[1] << " ] ";

    cout << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<vector<int>> intervals = {{1,3},{6,9}};

    vector<int> newInterval = {2,5};

    vector<vector<int>> temp = intervals;

    printAnswer("Approach 1: Brute Force",
                insertBruteForce(temp, newInterval));

    printAnswer("Approach 2: Optimal",
                insertOptimal(intervals, newInterval));

    return 0;
}
