// Problem: Evaluate Reverse Polish Notation
// LeetCode 150
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Recursive
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

int index;

int solve(vector<string>& tokens) {

    string token = tokens[index--];

    if (token != "+" &&
        token != "-" &&
        token != "*" &&
        token != "/") {

        return stoi(token);
    }

    int second = solve(tokens);
    int first = solve(tokens);

    if (token == "+") return first + second;
    if (token == "-") return first - second;
    if (token == "*") return first * second;

    return first / second;
}

int evalRPNRecursive(vector<string> tokens) {

    index = tokens.size() - 1;

    return solve(tokens);
}

/*------------------------------------------------------------
Approach 2: Stack (Optimal)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/

int evalRPNStack(vector<string> tokens) {

    stack<int> st;

    for (string token : tokens) {

        if (token == "+" ||
            token == "-" ||
            token == "*" ||
            token == "/") {

            int b = st.top();
            st.pop();

            int a = st.top();
            st.pop();

            if (token == "+")
                st.push(a + b);

            else if (token == "-")
                st.push(a - b);

            else if (token == "*")
                st.push(a * b);

            else
                st.push(a / b);
        }
        else {

            st.push(stoi(token));
        }
    }

    return st.top();
}

// Function to print answer
void printAnswer(string approach, int ans) {

    cout << approach << endl;
    cout << "Result: " << ans << endl;
    cout << "----------------------------------------" << endl;
}

int main() {

    vector<string> tokens = {
        "2",
        "1",
        "+",
        "3",
        "*"
    };

    printAnswer("Approach 1: Recursive",
                evalRPNRecursive(tokens));

    printAnswer("Approach 2: Stack (Optimal)",
                evalRPNStack(tokens));

    return 0;
}
