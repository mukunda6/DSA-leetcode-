// Problem: Asteroid Collision
// LeetCode 735
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Simulation (Brute Force)
Time Complexity: O(n²)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> asteroidCollisionBruteForce(vector<int> asteroids) {

    bool changed = true;

    while (changed) {

        changed = false;

        vector<int> temp;

        for (int i = 0; i < asteroids.size(); i++) {

            if (i + 1 < asteroids.size() &&
                asteroids[i] > 0 &&
                asteroids[i + 1] < 0) {

                changed = true;

                if (abs(asteroids[i]) > abs(asteroids[i + 1])) {

                    temp.push_back(asteroids[i]);
                }
                else if (abs(asteroids[i]) < abs(asteroids[i + 1])) {

                    temp.push_back(asteroids[i + 1]);
                }

                i++;
            }
            else {

                temp.push_back(asteroids[i]);
            }
        }

        asteroids = temp;
    }

    return asteroids;
}

/*------------------------------------------------------------
Approach 2: Stack (Optimal)
Time Complexity: O(n)
Space Complexity: O(n)
------------------------------------------------------------*/
vector<int> asteroidCollisionStack(vector<int> asteroids) {

    stack<int> st;

    for (int asteroid : asteroids) {

        bool destroyed = false;

        while (!st.empty() &&
               st.top() > 0 &&
               asteroid < 0) {

            if (st.top() < abs(asteroid)) {

                st.pop();
                continue;
            }

            if (st.top() == abs(asteroid)) {

                st.pop();
            }

            destroyed = true;
            break;
        }

        if (!destroyed) {

            st.push(asteroid);
        }
    }

    vector<int> ans(st.size());

    for (int i = st.size() - 1; i >= 0; i--) {

        ans[i] = st.top();
        st.pop();
    }

    return ans;
}

// Function to print answer
void printAnswer(string approach,
                 vector<int> ans) {

    cout << approach << endl;

    cout << "Output: ";

    for (int x : ans)
        cout << x << " ";

    cout << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<int> asteroids = {5, 10, -5};

    printAnswer("Approach 1: Simulation (Brute Force)",
                asteroidCollisionBruteForce(asteroids));

    printAnswer("Approach 2: Stack (Optimal)",
                asteroidCollisionStack(asteroids));

    return 0;
}
