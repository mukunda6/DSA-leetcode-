// Problem: Rotate Image
// LeetCode 48
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Extra Matrix
Time Complexity: O(n²)
Space Complexity: O(n²)
------------------------------------------------------------*/

vector<vector<int>> rotateImageExtraMatrix(vector<vector<int>> matrix) {

    int n = matrix.size();

    // Create a new matrix
    vector<vector<int>> ans(n, vector<int>(n));

    // Place every element in its rotated position
    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {

            ans[j][n - 1 - i] = matrix[i][j];
        }
    }

    return ans;
}

/*------------------------------------------------------------
Approach 2: Transpose + Reverse (Optimal)
Time Complexity: O(n²)
Space Complexity: O(1)
------------------------------------------------------------*/

vector<vector<int>> rotateImageOptimal(vector<vector<int>> matrix) {

    int n = matrix.size();

    // Step 1: Transpose the matrix
    for (int i = 0; i < n; i++) {

        for (int j = i + 1; j < n; j++) {

            swap(matrix[i][j], matrix[j][i]);
        }
    }

    // Step 2: Reverse every row
    for (int i = 0; i < n; i++) {

        reverse(matrix[i].begin(), matrix[i].end());
    }

    return matrix;
}

// Function to print matrix
void printAnswer(string approach, vector<vector<int>> matrix) {

    cout << approach << endl;

    for (auto row : matrix) {

        for (int x : row) {

            cout << x << " ";
        }

        cout << endl;
    }

    cout << "----------------------------------------" << endl;
}

int main() {

    // Example Test Case
    vector<vector<int>> matrix = {
        {1,2,3},
        {4,5,6},
        {7,8,9}
    };

    printAnswer("Approach 1: Extra Matrix",
                rotateImageExtraMatrix(matrix));

    printAnswer("Approach 2: Transpose + Reverse (Optimal)",
                rotateImageOptimal(matrix));

    return 0;
}
