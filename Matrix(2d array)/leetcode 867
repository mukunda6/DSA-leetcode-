// Problem: Transpose Matrix
// LeetCode 867
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force (Create New Matrix)
Time Complexity: O(m × n)
Space Complexity: O(m × n)
------------------------------------------------------------*/

vector<vector<int>> transposeBruteForce(vector<vector<int>> matrix) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Create a transpose matrix of size n × m
    vector<vector<int>> ans(n, vector<int>(m));

    // Copy elements by swapping row and column indices
    for (int i = 0; i < m; i++) {

        for (int j = 0; j < n; j++) {

            ans[j][i] = matrix[i][j];
        }
    }

    return ans;
}

/*------------------------------------------------------------
Approach 2: In-Place Transpose (Square Matrix Only)
Time Complexity: O(n²)
Space Complexity: O(1)
------------------------------------------------------------*/

vector<vector<int>> transposeInPlace(vector<vector<int>> matrix) {

    int n = matrix.size();

    // Swap elements across the main diagonal
    for (int i = 0; i < n; i++) {

        for (int j = i + 1; j < n; j++) {

            swap(matrix[i][j], matrix[j][i]);
        }
    }

    return matrix;
}

// Function to print matrix
void printAnswer(string approach, vector<vector<int>> matrix) {

    cout << approach << endl;

    for (auto row : matrix) {

        for (int x : row) {

            cout << x << " ";
        }

        cout << endl;
    }

    cout << "----------------------------------------" << endl;
}

int main() {

    // Example 1 (Works for both approaches)
    vector<vector<int>> matrix = {
        {1,2,3},
        {4,5,6},
        {7,8,9}
    };

    printAnswer("Approach 1: Brute Force",
                transposeBruteForce(matrix));

    printAnswer("Approach 2: In-Place (Square Matrix)",
                transposeInPlace(matrix));

    return 0;
}
