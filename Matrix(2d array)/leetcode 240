// Problem: Search a 2D Matrix II
// LeetCode 240
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(m × n)
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixBruteForce(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Traverse every element
    for (int i = 0; i < m; i++) {

        for (int j = 0; j < n; j++) {

            if (matrix[i][j] == target)
                return true;
        }
    }

    return false;
}

/*------------------------------------------------------------
Approach 2: Binary Search on Every Row
Time Complexity: O(m × log n)
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixRowBinary(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Perform binary search on every row
    for (int i = 0; i < m; i++) {

        int low = 0;
        int high = n - 1;

        while (low <= high) {

            int mid = low + (high - low) / 2;

            if (matrix[i][mid] == target)
                return true;

            if (matrix[i][mid] < target)
                low = mid + 1;
            else
                high = mid - 1;
        }
    }

    return false;
}

/*------------------------------------------------------------
Approach 3: Binary Search on Every Column
Time Complexity: O(n × log m)
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixColumnBinary(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Perform binary search on every column
    for (int j = 0; j < n; j++) {

        int low = 0;
        int high = m - 1;

        while (low <= high) {

            int mid = low + (high - low) / 2;

            if (matrix[mid][j] == target)
                return true;

            if (matrix[mid][j] < target)
                low = mid + 1;
            else
                high = mid - 1;
        }
    }

    return false;
}

/*------------------------------------------------------------
Approach 4: Staircase Search (Optimal)
Time Complexity: O(m + n)
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixOptimal(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Start from the top-right corner
    int row = 0;
    int col = n - 1;

    while (row < m && col >= 0) {

        if (matrix[row][col] == target)
            return true;

        // Move left
        if (matrix[row][col] > target)
            col--;

        // Move down
        else
            row++;
    }

    return false;
}

// Function to print answer
void printAnswer(string approach, bool ans) {

    cout << approach << endl;

    cout << "Target Found: "
         << (ans ? "True" : "False") << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<vector<int>> matrix = {
        {1,4,7,11,15},
        {2,5,8,12,19},
        {3,6,9,16,22},
        {10,13,14,17,24},
        {18,21,23,26,30}
    };

    int target = 20;

    printAnswer("Approach 1: Brute Force",
                searchMatrixBruteForce(matrix, target));

    printAnswer("Approach 2: Binary Search on Every Row",
                searchMatrixRowBinary(matrix, target));

    printAnswer("Approach 3: Binary Search on Every Column",
                searchMatrixColumnBinary(matrix, target));

    printAnswer("Approach 4: Staircase Search (Optimal)",
                searchMatrixOptimal(matrix, target));

    return 0;
}
