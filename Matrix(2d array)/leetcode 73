// Problem: Set Matrix Zeroes
// LeetCode 73
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Row & Column Marker Arrays
Time Complexity: O(m × n)
Space Complexity: O(m + n)
------------------------------------------------------------*/

vector<vector<int>> setZeroesBetter(vector<vector<int>> matrix) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Store rows and columns containing zero
    vector<int> row(m, 0);
    vector<int> col(n, 0);

    // Find all zeroes
    for (int i = 0; i < m; i++) {

        for (int j = 0; j < n; j++) {

            if (matrix[i][j] == 0) {

                row[i] = 1;
                col[j] = 1;
            }
        }
    }

    // Set required cells to zero
    for (int i = 0; i < m; i++) {

        for (int j = 0; j < n; j++) {

            if (row[i] || col[j]) {

                matrix[i][j] = 0;
            }
        }
    }

    return matrix;
}

/*------------------------------------------------------------
Approach 2: Constant Space (Optimal)
Time Complexity: O(m × n)
Space Complexity: O(1)
------------------------------------------------------------*/

vector<vector<int>> setZeroesOptimal(vector<vector<int>> matrix) {

    int n = matrix.size();
    int m = matrix[0].size();

    // Tracks whether first column should become zero
    int col0 = 1;

    // Use first row and first column as markers
    for (int i = 0; i < n; i++) {

        for (int j = 0; j < m; j++) {

            if (matrix[i][j] == 0) {

                matrix[i][0] = 0;

                if (j != 0) {

                    matrix[0][j] = 0;
                }
                else {

                    col0 = 0;
                }
            }
        }
    }

    // Update remaining cells
    for (int i = 1; i < n; i++) {

        for (int j = 1; j < m; j++) {

            if (matrix[i][j] != 0) {

                if (matrix[i][0] == 0 ||
                    matrix[0][j] == 0) {

                    matrix[i][j] = 0;
                }
            }
        }
    }

    // Update first row
    if (matrix[0][0] == 0) {

        for (int j = 0; j < m; j++) {

            matrix[0][j] = 0;
        }
    }

    // Update first column
    if (col0 == 0) {

        for (int i = 0; i < n; i++) {

            matrix[i][0] = 0;
        }
    }

    return matrix;
}

// Function to print matrix
void printAnswer(string approach, vector<vector<int>> matrix) {

    cout << approach << endl;

    for (auto row : matrix) {

        for (int x : row) {

            cout << x << " ";
        }

        cout << endl;
    }

    cout << "----------------------------------------" << endl;
}

int main() {

    // Example Test Case
    vector<vector<int>> matrix = {
        {1,1,1},
        {1,0,1},
        {1,1,1}
    };

    printAnswer("Approach 1: Row & Column Marker Arrays",
                setZeroesBetter(matrix));

    printAnswer("Approach 2: Constant Space (Optimal)",
                setZeroesOptimal(matrix));

    return 0;
}
