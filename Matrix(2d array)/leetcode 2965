// Problem: Find Missing and Repeated Values
// LeetCode 2965
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Hash Set + Sum Formula (Optimal)
Time Complexity: O(n²)
Space Complexity: O(n²)
------------------------------------------------------------*/

vector<int> findMissingAndRepeatedValues(vector<vector<int>> grid) {

    vector<int> ans;

    int n = grid.size();

    // Store visited numbers
    unordered_set<int> seen;

    int actualSum = 0;
    int expectedSum = 0;

    int repeated;
    int missing;

    // Traverse the matrix
    for (int i = 0; i < n; i++) {

        for (int j = 0; j < n; j++) {

            actualSum += grid[i][j];

            // Repeated number found
            if (seen.find(grid[i][j]) != seen.end()) {

                repeated = grid[i][j];
                ans.push_back(repeated);
            }

            seen.insert(grid[i][j]);
        }
    }

    // Sum of numbers from 1 to n²
    expectedSum = (n * n) * (n * n + 1) / 2;

    // Missing Number
    missing = expectedSum + repeated - actualSum;

    ans.push_back(missing);

    return ans;
}

// Function to print answer
void printAnswer(vector<int> ans) {

    cout << "Repeated Number: " << ans[0] << endl;
    cout << "Missing Number : " << ans[1] << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    // Example Test Case
    vector<vector<int>> grid = {
        {1,3},
        {2,2}
    };

    vector<int> ans = findMissingAndRepeatedValues(grid);

    printAnswer(ans);

    return 0;
}
