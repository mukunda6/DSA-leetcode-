// Problem: Search a 2D Matrix
// LeetCode 74
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Brute Force
Time Complexity: O(m × n)
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixBruteForce(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Traverse every element
    for (int i = 0; i < m; i++) {

        for (int j = 0; j < n; j++) {

            if (matrix[i][j] == target)
                return true;
        }
    }

    return false;
}

/*------------------------------------------------------------
Approach 2: Binary Search on Every Row
Time Complexity: O(m × log n)
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixRowBinary(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Perform binary search on each row
    for (int i = 0; i < m; i++) {

        int low = 0;
        int high = n - 1;

        while (low <= high) {

            int mid = low + (high - low) / 2;

            if (matrix[i][mid] == target)
                return true;

            if (matrix[i][mid] < target)
                low = mid + 1;
            else
                high = mid - 1;
        }
    }

    return false;
}

/*------------------------------------------------------------
Approach 3: Binary Search on Flattened Matrix (Optimal)
Time Complexity: O(log(m × n))
Space Complexity: O(1)
------------------------------------------------------------*/

bool searchMatrixOptimal(vector<vector<int>> matrix, int target) {

    int m = matrix.size();
    int n = matrix[0].size();

    int low = 0;
    int high = m * n - 1;

    // Treat matrix as a sorted 1D array
    while (low <= high) {

        int mid = low + (high - low) / 2;

        int row = mid / n;
        int col = mid % n;

        if (matrix[row][col] == target)
            return true;

        if (matrix[row][col] < target)
            low = mid + 1;
        else
            high = mid - 1;
    }

    return false;
}

// Function to print answer
void printAnswer(string approach, bool ans) {

    cout << approach << endl;

    cout << "Target Found: "
         << (ans ? "True" : "False") << endl;

    cout << "----------------------------------------" << endl;
}

int main() {

    vector<vector<int>> matrix = {
        {1,3,5,7},
        {10,11,16,20},
        {23,30,34,60}
    };

    int target = 3;

    printAnswer("Approach 1: Brute Force",
                searchMatrixBruteForce(matrix, target));

    printAnswer("Approach 2: Binary Search on Every Row",
                searchMatrixRowBinary(matrix, target));

    printAnswer("Approach 3: Flattened Matrix Binary Search (Optimal)",
                searchMatrixOptimal(matrix, target));

    return 0;
}
