// Problem: Spiral Matrix
// LeetCode 54
// Platform: LeetCode / CodeChef

#include <bits/stdc++.h>
using namespace std;

/*------------------------------------------------------------
Approach 1: Boundary Traversal (Optimal)
Time Complexity: O(m × n)
Space Complexity: O(1) (excluding output array)
------------------------------------------------------------*/

vector<int> spiralOrder(vector<vector<int>> matrix) {

    int m = matrix.size();
    int n = matrix[0].size();

    // Initialize four boundaries
    int startRow = 0;
    int endRow = m - 1;
    int startCol = 0;
    int endCol = n - 1;

    vector<int> ans;

    // Traverse while boundaries are valid
    while (startRow <= endRow &&
           startCol <= endCol) {

        // Traverse Left → Right
        for (int j = startCol; j <= endCol; j++) {

            ans.push_back(matrix[startRow][j]);
        }

        // Traverse Top → Bottom
        for (int i = startRow + 1; i <= endRow; i++) {

            ans.push_back(matrix[i][endCol]);
        }

        // Traverse Right → Left
        for (int j = endCol - 1; j >= startCol; j--) {

            // Avoid duplicate row
            if (startRow == endRow)
                break;

            ans.push_back(matrix[endRow][j]);
        }

        // Traverse Bottom → Top
        for (int i = endRow - 1; i >= startRow + 1; i--) {

            // Avoid duplicate column
            if (startCol == endCol)
                break;

            ans.push_back(matrix[i][startCol]);
        }

        // Move boundaries inward
        startRow++;
        endRow--;

        startCol++;
        endCol--;
    }

    return ans;
}

// Function to print answer
void printAnswer(vector<int> ans) {

    cout << "Spiral Order: ";

    for (int x : ans) {

        cout << x << " ";
    }

    cout << endl;
}

int main() {

    // Example Test Case
    vector<vector<int>> matrix = {
        {1,2,3},
        {4,5,6},
        {7,8,9}
    };

    vector<int> ans = spiralOrder(matrix);

    printAnswer(ans);

    return 0;
}
